# ================================
# TELEGRAM
# ================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Твой Telegram user ID (для защиты — бот будет отвечать только тебе)
# Узнать можно написав @userinfobot в Telegram
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id_here

# ================================
# AI APIs
# ================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ================================
# DESKTOP AGENT
# ================================
# Локальный сервер — не менять без необходимости
DESKTOP_AGENT_URL=http://localhost:8001
DESKTOP_AGENT_SECRET=change_this_to_random_string

# ================================
# OBSIDIAN
# ================================
# Полный путь к папке твоего Obsidian Vault
OBSIDIAN_VAULT_PATH=/Users/your_username/Documents/ObsidianVault
